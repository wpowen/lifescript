[
  {
    "id": "ch_001",
    "book_id": "urban_001",
    "number": 1,
    "title": "宗祠之辱",
    "is_paid": false,
    "next_chapter_hook": "古戒的声音再次响起：'你的选择，已经开始改变命运的轨迹。明天的宗门大比，将是你第一次真正的考验。'林月今晚会来找你——她似乎察觉到了什么……",
    "nodes": [
      {
        "text": {
          "id": "n_001_01",
          "content": "深夜。林家宗祠。",
          "emphasis": "dramatic"
        }
      },
      {
        "text": {
          "id": "n_001_02",
          "content": "你跪在冰冷的石板上，膝盖已经麻木。四周烛火摇曳，祖先牌位在阴影中若隐若现。"
        }
      },
      {
        "text": {
          "id": "n_001_03",
          "content": "满堂长老端坐在高位，目光冷漠地俯视着你——就像看一只等待宰杀的羔羊。"
        }
      },
      {
        "dialogue": {
          "id": "n_001_04",
          "character_id": "char_elder_three",
          "content": "三年了，你还有脸回来？当初若不是老族长护着你，你连跪在这里的资格都没有。",
          "emotion": "冷笑"
        }
      },
      {
        "text": {
          "id": "n_001_05",
          "content": "三长老一脚踢翻你面前的供桌，茶水溅在你脸上。周围传来低低的嗤笑声。"
        }
      },
      {
        "dialogue": {
          "id": "n_001_06",
          "character_id": "char_zhang_wei",
          "content": "三长老说得对，废物就是废物。三年前测不出灵根，三年后还是一样。林家不养废物。",
          "emotion": "嘲讽"
        }
      },
      {
        "text": {
          "id": "n_001_07",
          "content": "你攥紧拳头，指甲嵌入掌心。你感觉到无名指上的古戒微微发烫——三年来第一次。"
        }
      },
      {
        "text": {
          "id": "n_001_08",
          "content": "一道只有你能听见的声音，在脑海中响起：",
          "emphasis": "system"
        }
      },
      {
        "text": {
          "id": "n_001_09",
          "content": "「封印已开始松动。宿主，现在你有三个选择。每个选择，都将改变你的命运轨迹。」",
          "emphasis": "system"
        }
      },
      {
        "choice": {
          "id": "choice_001_01",
          "prompt": "你的体内涌起一股前所未有的力量。此刻，你选择——",
          "choice_type": "keyDecision",
          "choices": [
            {
              "id": "c_001_01_a",
              "text": "当场摊牌，震碎测灵石",
              "description": "释放封印之力，让所有人看到真正的你。三长老的脸，今晚就要打。",
              "satisfaction_type": "直接爽",
              "stat_effects": [
                { "stat": "战力", "delta": 15 },
                { "stat": "名望", "delta": 10 },
                { "stat": "天命值", "delta": -5 }
              ],
              "relationship_effects": [
                { "character_id": "char_elder_three", "dimension": "敬畏", "delta": 25 },
                { "character_id": "char_elder_three", "dimension": "敌意", "delta": 15 },
                { "character_id": "char_zhang_wei", "dimension": "敬畏", "delta": 20 },
                { "character_id": "char_lin_yue", "dimension": "好感", "delta": 10 }
              ],
              "result_node_ids": ["result_001_a"],
              "result_nodes": [
                {
                  "text": {
                    "id": "urban_result_001_a_01",
                    "content": "你缓缓起身，掌心贴上测灵石的瞬间，古戒像被点燃一般灼热。下一秒，压抑了三年的灵力轰然冲出，整块测灵石从中间炸开，碎屑溅了满堂。"
                  }
                },
                {
                  "dialogue": {
                    "id": "urban_result_001_a_02",
                    "character_id": "char_elder_three",
                    "content": "你竟然敢在宗祠放肆？！",
                    "emotion": "震怒"
                  }
                },
                {
                  "text": {
                    "id": "urban_result_001_a_03",
                    "content": "你抬眼看向高位，声音不高，却让整座宗祠都静了下来：'三年前你们说我是废物。现在，谁还敢再说一次？'",
                    "emphasis": "dramatic"
                  }
                }
              ],
              "is_premium": false
            },
            {
              "id": "c_001_01_b",
              "text": "忍下羞辱，暗中布局",
              "description": "今晚不是时候。记住每一张嘲笑的脸，三个月后宗门大比再一一清算。",
              "satisfaction_type": "延迟爽",
              "stat_effects": [
                { "stat": "谋略", "delta": 15 },
                { "stat": "天命值", "delta": 10 },
                { "stat": "黑化值", "delta": 5 }
              ],
              "relationship_effects": [
                { "character_id": "char_old_chen", "dimension": "信任", "delta": 15 },
                { "character_id": "char_lin_yue", "dimension": "好感", "delta": -5 }
              ],
              "result_node_ids": ["result_001_b"],
              "result_nodes": [
                {
                  "text": {
                    "id": "urban_result_001_b_01",
                    "content": "你把那股几乎要冲出胸腔的力量硬生生压了回去，任由掌心被指甲掐出血痕。表面上你仍旧低着头，像是真的认命了。"
                  }
                },
                {
                  "text": {
                    "id": "urban_result_001_b_02",
                    "content": "可你的目光一一扫过堂上的每一张脸，把三长老、张威、还有那些低笑的人全都记进心里。古戒在指间轻轻一震，像是在替你把这笔账落档。"
                  }
                },
                {
                  "dialogue": {
                    "id": "urban_result_001_b_03",
                    "character_id": "char_old_chen",
                    "content": "能忍住这一口气，少爷才真的是开始了。",
                    "emotion": "低不可闻"
                  }
                }
              ],
              "is_premium": false
            },
            {
              "id": "c_001_01_c",
              "text": "假意认错，先骗走藏宝阁钥匙",
              "description": "既然他们看不起你，就让他们继续小看。趁机拿到藏宝阁钥匙，里面有你需要的东西。",
              "satisfaction_type": "阴谋爽",
              "stat_effects": [
                { "stat": "谋略", "delta": 10 },
                { "stat": "财富", "delta": 15 },
                { "stat": "魅力", "delta": 5 },
                { "stat": "黑化值", "delta": 10 }
              ],
              "relationship_effects": [
                { "character_id": "char_elder_three", "dimension": "信任", "delta": 10 },
                { "character_id": "char_old_chen", "dimension": "信任", "delta": -10 }
              ],
              "result_node_ids": ["result_001_c"],
              "result_nodes": [
                {
                  "text": {
                    "id": "urban_result_001_c_01",
                    "content": "你忽然低头认错，语气甚至带上一丝惶恐。满堂长老先是一愣，随即露出果然如此的冷笑，三长老更是得意地把腰间钥匙在手里转了两圈。"
                  }
                },
                {
                  "text": {
                    "id": "urban_result_001_c_02",
                    "content": "就在他抬手示意你滚去藏宝阁受罚的瞬间，你借着俯身叩首的角度，视线已经锁定了那串青铜钥匙的纹路和挂扣位置。"
                  }
                },
                {
                  "text": {
                    "id": "urban_result_001_c_03",
                    "content": "你把姿态放得越低，心里的笑意反而越冷。今晚他们会以为你彻底服了，可真正要失去东西的人，不会是你。",
                    "emphasis": "dramatic"
                  }
                }
              ],
              "is_premium": false
            }
          ]
        }
      },
      {
        "text": {
          "id": "n_001_10",
          "content": "你做出了选择。古戒上的纹路闪过一道微光，仿佛在回应你的决定。",
          "emphasis": "dramatic"
        }
      },
      {
        "text": {
          "id": "n_001_11",
          "content": "在宗祠的角落里，陈伯默默注视着这一切。他浑浊的眼中，闪过一丝不易察觉的光芒。"
        }
      },
      {
        "dialogue": {
          "id": "n_001_12",
          "character_id": "char_old_chen",
          "content": "少爷……终于要开始了吗。",
          "emotion": "低语"
        }
      },
      {
        "text": {
          "id": "n_001_13",
          "content": "夜色深沉，你走出宗祠。身后，林月的目光一直追随着你的背影。"
        }
      },
      {
        "dialogue": {
          "id": "n_001_14",
          "character_id": "char_lin_yue",
          "content": "你……今晚怎么不一样了？",
          "emotion": "若有所思"
        }
      },
      {
        "choice": {
          "id": "choice_001_02",
          "prompt": "林月追了出来。月光下，她的表情带着一丝担忧和好奇。你——",
          "choice_type": "characterPref",
          "choices": [
            {
              "id": "c_001_02_a",
              "text": "微微一笑，什么都不说",
              "description": "有些事，不需要解释。让她自己去猜。",
              "satisfaction_type": "扮猪吃虎",
              "stat_effects": [
                { "stat": "魅力", "delta": 10 }
              ],
              "relationship_effects": [
                { "character_id": "char_lin_yue", "dimension": "好感", "delta": 15 },
                { "character_id": "char_lin_yue", "dimension": "信任", "delta": -5 }
              ],
              "result_node_ids": [],
              "result_nodes": [
                {
                  "text": {
                    "id": "urban_result_002_a_01",
                    "content": "你只是看着她，唇角微微抬了一下，却什么都没解释。月色落在你眼底，把那点若有若无的锋芒照得格外清晰。"
                  }
                },
                {
                  "dialogue": {
                    "id": "urban_result_002_a_02",
                    "character_id": "char_lin_yue",
                    "content": "你明明什么都没说，可我总觉得你已经把后面的路都想好了。",
                    "emotion": "怔住"
                  }
                }
              ],
              "is_premium": false
            },
            {
              "id": "c_001_02_b",
              "text": "告诉她：'一切都会不一样的。等着看。'",
              "description": "给她一个承诺，也给自己一个期限。",
              "satisfaction_type": "直接爽",
              "stat_effects": [
                { "stat": "名望", "delta": 5 },
                { "stat": "魅力", "delta": 5 }
              ],
              "relationship_effects": [
                { "character_id": "char_lin_yue", "dimension": "好感", "delta": 10 },
                { "character_id": "char_lin_yue", "dimension": "信任", "delta": 10 }
              ],
              "result_node_ids": [],
              "result_nodes": [
                {
                  "text": {
                    "id": "urban_result_002_b_01",
                    "content": "你迎着林月的目光，把那句话说得很慢。不是逞强，也不是发狠，而像是在给她，也给自己定下一个不会退让的期限。"
                  }
                },
                {
                  "dialogue": {
                    "id": "urban_result_002_b_02",
                    "character_id": "char_lin_yue",
                    "content": "好。我等着看你把他们一个个踩下去。",
                    "emotion": "轻轻点头"
                  }
                }
              ],
              "is_premium": false
            }
          ]
        }
      },
      {
        "text": {
          "id": "n_001_15",
          "content": "月光洒在林家大院，你转身离去。掌心中的古戒温热如火。\n\n这一夜之后，一切都将不同。",
          "emphasis": "dramatic"
        }
      }
    ]
  },
